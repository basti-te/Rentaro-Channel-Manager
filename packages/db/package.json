{
  "name": "@cm/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts"
  },
  "scripts": {
    "generate": "drizzle-kit generate",
    "migrate": "drizzle-kit migrate && tsx scripts/apply-post-migrate.ts",
    "migrate:tables-only": "drizzle-kit migrate",
    "migrate:post": "tsx scripts/apply-post-migrate.ts",
    "seed": "tsx scripts/seed.ts",
    "verify": "tsx scripts/verify.ts",
    "dump": "tsx scripts/dump.ts",
    "setup-channex-mapping": "tsx scripts/setup-channex-mapping.ts",
    "sync-jobs:latest": "tsx scripts/latest-sync-job.ts",
    "webhooks:latest": "tsx scripts/latest-webhook.ts",
    "push": "drizzle-kit push",
    "studio": "drizzle-kit studio",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "drizzle-orm": "^0.36.4",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "dotenv": "^16.4.5",
    "drizzle-kit": "^0.28.1",
    "tsx": "^4.19.1",
    "typescript": "^5.5.4"
  }
}
