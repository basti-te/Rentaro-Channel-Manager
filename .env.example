# Copy to .env.local and fill in. NEVER commit .env.local.

# ---------- Node ----------
NODE_ENV=development

# ---------- Supabase ----------
# Get from https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres connection (for Drizzle migrations + server-side queries)
# Get from https://supabase.com/dashboard/project/_/settings/database
# Use the "Session" pooler URL (port 5432) for migrations, "Transaction" pooler (6543) for runtime
DATABASE_URL=postgres://postgres.YOUR-PROJECT:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
DATABASE_URL_DIRECT=postgres://postgres.YOUR-PROJECT:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:5432/postgres

# ---------- Channex (Whitelabel) ----------
# Sandbox while developing, swap to production at launch
CHANNEX_API_URL=https://staging.channex.io/api/v1
CHANNEX_API_KEY=
# Secret in webhook URL path (random string per environment)
CHANNEX_WEBHOOK_SECRET=

# ---------- Inngest ----------
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ---------- Stripe ----------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# ---------- Twilio (SMS) ----------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+49...

# ---------- Resend (Email) ----------
RESEND_API_KEY=
RESEND_FROM=noreply@yourdomain.tld

# ---------- Sentry ----------
SENTRY_DSN=

# ---------- App ----------
APP_URL=http://localhost:5173
API_URL=http://localhost:3001
