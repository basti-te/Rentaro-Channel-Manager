# Copy to .env.local and fill in. NEVER commit .env.local.
#
# This file is the source of truth for env vars the code actually reads
# (apps/worker/src/env.ts + apps/web/src/env.d.ts). Aspirational vars
# (e.g. Sentry, Resend) are not listed here — add them when their code
# lands.

# ---------- Node ----------
NODE_ENV=development
# Port the worker listens on (defaults to 3001 if unset).
PORT=3001

# ---------- Supabase (server-side) ----------
# https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---------- Database ----------
# https://supabase.com/dashboard/project/_/settings/database
# DATABASE_URL → Transaction pooler (port 6543) for runtime.
# DATABASE_URL_DIRECT → Direct connection (port 5432) for `pnpm --filter @cm/db migrate`.
# URL-encode special chars in the password (`!` → `%21`).
DATABASE_URL=postgres://postgres.YOUR-PROJECT:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
DATABASE_URL_DIRECT=postgres://postgres.YOUR-PROJECT:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:5432/postgres

# ---------- App URLs ----------
# Public URL of the Vite SPA. Used for CORS on the worker and for the
# Stripe Checkout / Customer Portal return URL.
APP_URL=http://localhost:5173
# Public base URL where the worker is reachable from the internet (no
# trailing slash). Used to build Twilio status-callback URLs etc.
# Unset in local dev → Twilio status callback is skipped.
PUBLIC_WEBHOOK_BASE_URL=

# ---------- Supabase (browser-side, exposed via Vite) ----------
# These mirror SUPABASE_URL / SUPABASE_ANON_KEY but with the VITE_ prefix
# so Vite inlines them into the client bundle. Anon key only — never put
# SERVICE_ROLE_KEY into a VITE_ var.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=
# Where the SPA sends tRPC requests. In dev with Vite's proxy you can
# leave it empty (falls back to "/trpc"). In production set to the worker
# URL, e.g. https://channel-manager.up.railway.app/trpc
VITE_API_URL=

# ---------- Channex (Whitelabel) ----------
# Sandbox while developing, swap to production at launch (see status.md
# "Resetting for production switch").
CHANNEX_API_URL=https://staging.channex.io/api/v1
CHANNEX_API_KEY=
# Path-secret in the inbound webhook URL (Channex doesn't HMAC-sign).
# Generate a random 48+ char string per environment.
CHANNEX_WEBHOOK_SECRET=

# ---------- Inngest ----------
# All optional in local dev — the inngest-cli (`npx inngest-cli@latest dev …`)
# auto-detects an unauthenticated local worker. Required in production
# (Inngest Cloud — see docs/deployment.md §2).
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
# Optional: override the Inngest cloud URL. Leave empty for default.
INNGEST_BASE_URL=
# Optional: override the registered app id. Defaults to "channel-manager".
INNGEST_APP_ID=

# ---------- Stripe (SaaS billing — see docs/stripe-setup.md) ----------
# All optional — billing degrades to "not configured" if unset.
# Test mode for dev; swap with sk_live_* + live whsec + live price IDs at launch.
STRIPE_SECRET_KEY=
# `stripe listen` prints this in dev. Production: copy from the
# webhook endpoint in the Stripe Dashboard.
STRIPE_WEBHOOK_SECRET=
# The 4 Stripe Prices for the hybrid pricing model (base + per-property,
# each as monthly + annual −10 %). Create in Stripe Dashboard → Products.
STRIPE_PRICE_BASE_MONTHLY=
STRIPE_PRICE_BASE_ANNUAL=
STRIPE_PRICE_PROPERTY_MONTHLY=
STRIPE_PRICE_PROPERTY_ANNUAL=

# ---------- Resend (operator e-mail notifications) ----------
# All optional — notifications degrade to "not configured" if unset.
# https://resend.com → verify a sender domain, then create an API key.
RESEND_API_KEY=
# From header. The domain must be verified in Resend.
RESEND_FROM=Rentaro <alerts@rentaro.cloud>

# ---------- Twilio (SMS) ----------
# All optional — message/cleaning automation degrade gracefully if unset.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Sender: E.164 number (+49…) OR an approved alphanumeric sender id
# (≤11 chars, ≥1 letter, only A–Z a–z 0–9 spaces). Per-tenant override
# in tenants.sms_sender_id wins over this.
TWILIO_FROM=
# Path-secret for the Twilio delivery-status webhook (optional). Without
# this set OR without PUBLIC_WEBHOOK_BASE_URL, delivery status callbacks
# are skipped (status stays at "sent" instead of advancing to "delivered").
TWILIO_STATUS_SECRET=
